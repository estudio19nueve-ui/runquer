{
  "expo": {
    "name": "Runquer",
    "slug": "runquer-app",
    "scheme": "runquer",
    "version": "2.5.5",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.estudio19nueve.runquer",
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.applesignin": [
          "Default"
        ]
      },
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "UIBackgroundModes": [
          "location",
          "fetch",
          "audio"
        ],
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Runquer necesita tu ubicación en todo momento para registrar tus rutas y conquistar territorios, incluso con la pantalla bloqueada.",
        "NSLocationWhenInUseUsageDescription": "Runquer necesita tu ubicación para registrar tus rutas.",
        "NSMotionUsageDescription": "Runquer utiliza el movimiento para optimizar el consumo de batería durante el seguimiento de actividad."
      }
    },
    "android": {
      "package": "com.runquer.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.ACTIVITY_RECOGNITION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.WAKE_LOCK"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "@kingstinct/react-native-healthkit",
        {
          "healthSharePermission": "Runquer necesita leer tus entrenos y rutas GPS para importar tus carreras conquistadas.",
          "healthUpdatePermission": "Runquer no guardará datos de salud en tu dispositivo."
        }
      ],
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsImpl": "mapbox"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Runquer necesita tu ubicación para registrar tus rutas y conquistar territorios."
        }
      ],
      [
        "expo-gradle-ext-vars",
        {
          "googlePlayServicesLocationVersion": "21.3.0"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.796377992566-gp8idrf367j30ajnj8vp6nf46nnl1kto"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "6819a2df-3ddf-48b8-88cb-fee57ee739df"
      }
    }
  }
}
